# Application
NODE_ENV=development
PORT=3000
APP_NAME=insta-uploader

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=insta_uploader

# Instagram Platform API (Instagram Login)
IG_APP_ID=your_instagram_app_id
IG_APP_SECRET=your_instagram_app_secret
IG_REDIRECT_URI=http://localhost:3000/api/instagram/auth/callback
IG_API_VERSION=v25.0
IG_POLLING_INTERVAL_MS=2000
IG_MAX_POLLING_ATTEMPTS=30

# Authentication
AUTH_PROVIDER=auth0              # Options: auth0, clerk, workos, stytch, zitadel
AUTH_REQUIRE_MFA=false           # Set to 'true' to enforce MFA on all protected routes

# Auth0 (required when AUTH_PROVIDER=auth0)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-audience
AUTH0_NAMESPACE=                 # Optional: custom claim namespace (defaults to https://{domain})

# Clerk (required when AUTH_PROVIDER=clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# WorkOS (required when AUTH_PROVIDER=workos)
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...

# Stytch (required when AUTH_PROVIDER=stytch)
STYTCH_PROJECT_ID=project-test-...
STYTCH_SECRET=secret-test-...

# Zitadel (required when AUTH_PROVIDER=zitadel)
ZITADEL_DOMAIN=your-instance.zitadel.cloud
ZITADEL_PROJECT_ID=12345678
